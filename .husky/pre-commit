#!/usr/bin/env sh

# If user is attempting an empty commit, don't run expensive checks.
INITIAL_STAGED_FILES="$(git diff --cached --name-only)"
if [ -z "$INITIAL_STAGED_FILES" ]; then
  echo "No staged files; skipping pre-commit checks."
  exit 0
fi

# Keep generated shared catalog in sync for every commit, even when
# only workflow/docs files changed.
npm run generate:shared-catalog
if ! git diff --quiet -- src/ui/generatedSharedCatalog.ts; then
  git add src/ui/generatedSharedCatalog.ts
  echo "Staged updated shared catalog (src/ui/generatedSharedCatalog.ts)."
fi

STAGED_FILES="$(git diff --cached --name-only)"
if [ -z "$STAGED_FILES" ]; then
  echo "No staged files after catalog sync; skipping pre-commit checks."
  exit 0
fi

# ── Fast checks first (fail within seconds) ──────────────────────────

# Always run canonical import-boundary guard so local presubmit
# matches CI behavior and catches boundary regressions early.
npm run check:import-boundaries

# Lint & auto-fix staged files (eslint + prettier)
npx lint-staged --allow-empty

# Dead-code / unused-file check (fast, ~1-2s)
npm run knip

# ── Slow checks (only if code files changed) ─────────────────────────

# Check if any TypeScript/JavaScript files are staged
if git diff --cached --name-only --quiet -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' 'package*.json' 'vite.config.*' 'vitest.config.*' 'tsconfig*.json' 'eslint.config.*'; then
  echo "No TypeScript/JavaScript files changed, skipping tests..."
else
  npm run typecheck

  first_match() {
    pattern="$1"
    if command -v rg >/dev/null 2>&1; then
      printf '%s\n' "$STAGED_FILES" | rg -m 1 "$pattern"
    else
      printf '%s\n' "$STAGED_FILES" | grep -E "$pattern" | head -n 1
    fi
  }

  # Check if regression test files or cat app files are staged
  REGRESSION_FILES_CHANGED=$(first_match '\.regression\.test\.(ts|tsx)$|^src/cats/')
  BPM_BENCHMARK_FILES_CHANGED=$(first_match '^src/beat/utils/(bpmDetectionBenchmark\.test\.ts|tempoDetectorInterface\.ts|tempoDetectors\.ts|tempoDetectorCore\.ts|tempoEnsemble\.ts|syntheticAudioGenerator\.ts|bpmAccuracyTest\.ts)$')

  if [ -n "$BPM_BENCHMARK_FILES_CHANGED" ]; then
    echo "BPM detector files changed, running full tests including benchmarks..."
    INCLUDE_BEAT_BENCHMARK=true npm test
  elif [ -n "$REGRESSION_FILES_CHANGED" ]; then
    echo "Cat/regression files changed, running full tests..."
    npm test
  else
    echo "Running fast tests (excluding slow regression tests)..."
    npm run test:fast
  fi
fi
