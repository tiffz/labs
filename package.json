{
  "name": "labs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "generate:shared-catalog": "node scripts/generate-shared-catalog.mjs",
    "check:shared-catalog": "node scripts/generate-shared-catalog.mjs --check",
    "generate:labs-catalog": "node scripts/render-labs-catalog.mjs",
    "check:labs-catalog": "node scripts/render-labs-catalog.mjs --check",
    "rollback:candidates": "node scripts/list-rollback-candidates.mjs --count 20",
    "check:import-boundaries": "node scripts/check-import-boundaries.mjs",
    "check:ui-copy": "node scripts/check-ui-copy.mjs",
    "check:doc-links": "node scripts/check-doc-links.mjs",
    "check:agent-docs": "sh scripts/validate-agent-docs.sh",
    "check:knip-config": "node scripts/validate-knip-ignore.mjs",
    "check:css-important": "node scripts/check-css-important.mjs",
    "check:css-import-order": "node scripts/check-css-import-order.mjs",
    "check:workflows": "sh scripts/check-workflows.sh",
    "muscle:validate-assets": "node scripts/validate-muscle-assets.mjs",
    "muscle:export-glbs": "node scripts/export-muscle-procedural-glbs.mjs",
    "muscle:export-z-anatomy": "node scripts/export-muscle-z-anatomy-glbs.mjs",
    "muscle:sync-bridge": "node scripts/sync-muscle-z-anatomy-bridge.mjs",
    "muscle:sync-atlas-registry": "node scripts/sync-atlas-mesh-registry.mjs",
    "muscle:audit-export": "node scripts/audit-muscle-z-anatomy-export.mjs",
    "muscle:coverage": "MUSCLE_COVERAGE_REPORT=1 npx vitest run src/muscle/anatomy/anatomyCoverageLedger.test.ts",
    "muscle:inventory": "MUSCLE_RUNTIME_INVENTORY=1 npx vitest run src/muscle/anatomy/fullBodyRuntimeInventory.test.ts src/muscle/anatomy/anatomyCoverageLedger.test.ts",
    "muscle:export-pipeline": "node scripts/run-muscle-anatomy-export.mjs",
    "prelint": "npm run generate:shared-catalog && npm run generate:labs-catalog",
    "pretest": "npm run generate:shared-catalog && npm run generate:labs-catalog",
    "prebuild": "npm run generate:shared-catalog && npm run generate:labs-catalog",
    "check:shared-theme-contract": "node scripts/check-shared-theme-contract.mjs",
    "check:chrome-ui": "node scripts/check-chrome-ui-contract.mjs",
    "check:menu-a11y": "node scripts/check-menu-a11y-contract.mjs",
    "check:volume-slider": "node scripts/check-volume-slider-contract.mjs",
    "check:app-quality": "node scripts/check-app-quality-contract.mjs",
    "audit:lighthouse": "node scripts/lighthouse-audit.mjs",
    "build:labs-cookie-consent": "esbuild src/shared/legal/labsCookieConsentBrowser.ts --bundle --format=iife --platform=browser --target=es2018 --outfile=public/scripts/labs-cookie-consent.js --legal-comments=inline",
    "dev": "npm run generate:shared-catalog && npm run generate:labs-catalog && vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "lint": "eslint . && npm run check:shared-theme-contract",
    "deps:outdated": "npm outdated --long",
    "deps:update:safe": "npm update",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:session-bff": "npm run typecheck --prefix workers/labs-session-bff",
    "typecheck:full": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:fast": "FAST_TESTS=true vitest run",
    "test:full": "INCLUDE_BEAT_BENCHMARK=true vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:changed-apps": "node scripts/run-changed-app-tests.mjs",
    "test:session-bff": "vitest run --root workers/labs-session-bff --config vitest.config.ts",
    "test:bubble-quality": "vitest run src/shared/comic/speechBubblePath.test.ts src/shared/comic/speechBubblePathGeometry.test.ts src/shared/comic/speechBubbleLayout.test.ts src/shared/comic/speechBubbleForceLayout.test.ts src/shared/comic/speechBubbleSlotLayout.test.ts src/shared/comic/speechBubbleTailOverlap.test.ts src/shared/comic/sfxLoudness.test.ts src/shared/comic/speechBubbleQuality.test.ts src/shared/comic/speechBubbleValidationHarness.test.ts src/shared/comic/panelTextLayoutInvariants.test.ts src/scrapboard/audits/scrapboardLayoutAudit.test.ts",
    "test:staged": "node scripts/run-staged-tests.mjs",
    "test:e2e:scoped": "node scripts/run-scoped-e2e.mjs",
    "test:e2e:smoke": "playwright test \"e2e/smoke/.*\\.spec\\.ts$\"",
    "test:e2e:playback": "playwright test e2e/playback-ui-regressions.spec.ts",
    "test:e2e:interaction": "playwright test \"e2e/smoke/.*interaction.*\\.spec\\.ts$\"",
    "test:e2e:visual": "playwright test --project=visual e2e/visual/apps.visual.spec.ts",
    "test:e2e:visual:scoped": "tsx scripts/run-scoped-visual.mts",
    "test:e2e:visual:docker": "sh scripts/run-visual-docker.sh",
    "test:e2e:visual:update": "playwright test --project=visual e2e/visual/apps.visual.spec.ts --update-snapshots",
    "test:e2e:visual:update:fresh": "node scripts/refresh-visual-baselines.mjs",
    "test:e2e:visual:crossbrowser": "VISUAL_MULTI_BROWSER=true playwright test --project=visual --project=visual-firefox --project=visual-webkit e2e/visual/apps.visual.spec.ts",
    "test:e2e:visual:crossbrowser:update": "VISUAL_MULTI_BROWSER=true playwright test --project=visual --project=visual-firefox --project=visual-webkit e2e/visual/apps.visual.spec.ts --update-snapshots",
    "test:e2e:visual:report": "playwright show-report",
    "test:audio:regression": "vitest run src/shared/beat/regression/syntheticAudioGenerator.audio-regression.test.ts",
    "test:audio:regression:update": "UPDATE_AUDIO_BASELINES=true vitest run src/shared/beat/regression/syntheticAudioGenerator.audio-regression.test.ts",
    "test:regression": "npm run test:audio:regression && npm run test:e2e:visual",
    "test:audits": "vitest run src/words/utils/generationQualityAudit.test.ts src/story/audits/comprehensive-generation-audit.test.ts src/story/audits/placeholderLeakAudit.test.ts src/gesture/audits/gesturePreviewDisplayAudit.test.ts",
    "test:words:audit": "vitest run src/words/utils/generationQualityAudit.test.ts",
    "test:words:audit:verbose": "VITEST_VERBOSE_AUDIT=true vitest run src/words/utils/generationQualityAudit.test.ts",
    "test:story:audit": "vitest run src/story/audits/comprehensive-generation-audit.test.ts src/story/audits/placeholderLeakAudit.test.ts",
    "test:gesture:audit": "vitest run src/gesture/audits/gesturePreviewDisplayAudit.test.ts",
    "test:watch": "vitest",
    "test:watch:fast": "FAST_TESTS=true vitest",
    "test:changed": "git diff --name-only HEAD~1 -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | head -1 > /dev/null && npm test || echo 'No TypeScript/JavaScript files changed, skipping tests'",
    "preview": "vite preview",
    "deploy": "npm run test:fast && npm run build && gh-pages -d dist",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "presubmit": "node scripts/presubmit-with-timing.mjs",
    "presubmit:push": "npm run presubmit && npm run test:e2e:smoke && npm run test:e2e:playback && npm run audit:advisory",
    "audit:advisory": "npm audit --omit=dev --audit-level=high || echo 'ADVISORY: high/critical npm advisories found. Patch in-range with npm audit fix; majors via docs/DEPENDENCY_UPGRADE_PLAN.md.'",
    "ci:watch": "node scripts/ci-watch.mjs",
    "report:ci-health": "node scripts/ci-health-report.mjs",
    "report:ci-failure": "node scripts/ci-failure-summary.mjs",
    "report:test-duration": "node scripts/test-duration-report.mjs",
    "report:bundle-size": "node scripts/bundle-size-report.mjs",
    "diff:class": "node scripts/diff-change-class.mjs --json",
    "verify:layout": "node scripts/run-scoped-layout-heuristics.mjs",
    "audit-pipeline": "node scripts/audit-pipeline.js",
    "audit-refresh": "node scripts/audit-pipeline.js --force",
    "audit-refresh:fast": "node scripts/audit-pipeline.js --force --skip-code-audit",
    "melodia:ingest": "tsx scripts/melodia/ingest-folder.mts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/noto-music": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@likemybread/name-generator": "^1.0.1",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@mui/x-date-pickers": "^7.29.4",
    "@pdf-lib/fontkit": "^1.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "cmu-pronouncing-dictionary": "^3.0.0",
    "culori": "^4.0.2",
    "d3-force": "^3.0.0",
    "dayjs": "^1.11.20",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "essentia.js": "^0.1.3",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lamejsfixbug121": "^1.0.0",
    "material-react-table": "^3.2.1",
    "material-symbols": "^0.43.0",
    "midi-json-parser": "^8.1.73",
    "page-flip": "^2.0.7",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "syllable": "^5.0.1",
    "three": "^0.182.0",
    "three-bvh-csg": "^0.0.17",
    "three-mesh-bvh": "^0.9.10",
    "vexflow": "^5.0.0",
    "webmscore": "^1.2.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/culori": "^4.0.1",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "code-auditor-mcp": "^2.6.2",
    "esbuild": "^0.27.7",
    "eslint": "^9.30.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fake-indexeddb": "^6.2.5",
    "get-artist-title": "^1.3.1",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jscpd": "^4.0.9",
    "jsdom": "^26.1.0",
    "knip": "^5.62.0",
    "linkedom": "^0.18.12",
    "lint-staged": "^15.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-plugin-compression2": "^2.2.0",
    "vite-plugin-static-copy": "^3.1.1",
    "vitest": "^3.2.4"
  }
}
