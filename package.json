{
  "name": "labs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:shared-catalog": "node scripts/generate-shared-catalog.mjs",
    "check:shared-catalog": "node scripts/generate-shared-catalog.mjs --check",
    "rollback:candidates": "node scripts/list-rollback-candidates.mjs --count 20",
    "check:import-boundaries": "node scripts/check-import-boundaries.mjs",
    "prelint": "npm run generate:shared-catalog",
    "pretest": "npm run generate:shared-catalog",
    "prebuild": "npm run generate:shared-catalog",
    "check:shared-theme-contract": "node scripts/check-shared-theme-contract.mjs",
    "dev": "npm run generate:shared-catalog && vite --host",
    "build": "npm run knip && vite build",
    "build:analyze": "ANALYZE=true vite build",
    "lint": "eslint . && npm run check:shared-theme-contract && npm run knip -- --no-exit-code",
    "deps:outdated": "npm outdated --long",
    "deps:update:safe": "npm update",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:full": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:fast": "FAST_TESTS=true vitest run",
    "test:full": "INCLUDE_BEAT_BENCHMARK=true vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test \"e2e/smoke/.*\\.spec\\.ts$\"",
    "test:e2e:visual": "playwright test --project=visual e2e/visual/apps.visual.spec.ts",
    "test:e2e:visual:update": "playwright test --project=visual e2e/visual/apps.visual.spec.ts --update-snapshots",
    "test:e2e:visual:update:fresh": "node scripts/refresh-visual-baselines.mjs",
    "test:e2e:visual:crossbrowser": "VISUAL_MULTI_BROWSER=true playwright test --project=visual --project=visual-firefox --project=visual-webkit e2e/visual/apps.visual.spec.ts",
    "test:e2e:visual:crossbrowser:update": "VISUAL_MULTI_BROWSER=true playwright test --project=visual --project=visual-firefox --project=visual-webkit e2e/visual/apps.visual.spec.ts --update-snapshots",
    "test:e2e:visual:report": "playwright show-report",
    "test:audio:regression": "vitest run src/beat/utils/syntheticAudioGenerator.audio-regression.test.ts",
    "test:audio:regression:update": "UPDATE_AUDIO_BASELINES=true vitest run src/beat/utils/syntheticAudioGenerator.audio-regression.test.ts",
    "test:regression": "npm run test:audio:regression && npm run test:e2e:visual",
    "test:watch": "vitest",
    "test:watch:fast": "FAST_TESTS=true vitest",
    "test:changed": "git diff --name-only HEAD~1 -- '*.ts' '*.tsx' '*.js' '*.jsx' '*.json' | head -1 > /dev/null && npm test || echo 'No TypeScript/JavaScript files changed, skipping tests'",
    "preview": "vite preview",
    "deploy": "npm run test:fast && npm run build && gh-pages -d dist",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "bash -c 'npm run knip -- --no-exit-code'"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/noto-music": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@likemybread/name-generator": "^1.0.1",
    "@mui/material": "^7.3.9",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@spotify/basic-pitch": "^1.0.1",
    "cmu-pronouncing-dictionary": "^3.0.0",
    "essentia.js": "^0.1.3",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "lamejsfixbug121": "^1.0.0",
    "material-symbols": "^0.43.0",
    "midi-json-parser": "^8.1.73",
    "pdf-lib": "^1.17.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "syllable": "^5.0.1",
    "three": "^0.182.0",
    "three-bvh-csg": "^0.0.17",
    "vexflow": "^5.0.0",
    "webmscore": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
    "knip": "^5.62.0",
    "lint-staged": "^15.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-plugin-compression2": "^2.2.0",
    "vite-plugin-static-copy": "^3.1.1",
    "vitest": "^3.2.4"
  }
}
