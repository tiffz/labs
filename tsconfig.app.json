{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    /**
     * noUnusedLocals/Parameters are relaxed here because the app code relies
     * on destructured setters that TS cannot detect as used. The lint layer
     * (`eslint.config.js`) still flags genuinely dead imports; when we adopt
     * `eslint-plugin-unused-imports` (Phase 2) we can remove the relaxation.
     */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": false,
    "types": ["vite/client", "vitest/globals", "@react-three/fiber"]
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/e2e/**",
    "src/**/audits/**",
    "src/shared/test/**",
    "src/ui/generatedSharedCatalog.ts"
  ]
}
